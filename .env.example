# ─────────────────────────────────────────────────────────────────
# Cardshop — Environment Variables
# Copy this file to .env and fill in your values.
# On Render: set these in the "Environment" tab of your service.
# ─────────────────────────────────────────────────────────────────

# Reloadly API (https://www.reloadly.com)
# Get these from: Reloadly Dashboard → API Settings
RELOADLY_CLIENT_ID=your_client_id_here
RELOADLY_CLIENT_SECRET=your_client_secret_here
RELOADLY_ENV=sandbox   # Change to "production" when ready to go live

# Database path (optional — defaults to cardshop.db in the working directory)
# On Render: use a persistent disk path, e.g. /var/data/cardshop.db
DB_PATH=cardshop.db

# ─────────────────────────────────────────────────────────────────
# Future integrations (not yet wired up)
# ─────────────────────────────────────────────────────────────────
# FLUTTERWAVE_PUBLIC_KEY=
# FLUTTERWAVE_SECRET_KEY=
# STRIPE_SECRET_KEY=
# NOWPAYMENTS_API_KEY=
# SENDGRID_API_KEY=
# WHATSAPP_NUMBER=
